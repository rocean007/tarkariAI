# Your own model backend endpoint
# Example: http://127.0.0.1:8000/v1
TARKARI_AI_BASE_URL=http://127.0.0.1:8000/v1

# Optional auth key for your own model backend
TARKARI_AI_API_KEY=
TARKARI_AI_MODEL=tarkari-chat-v1

# Pre-issued API keys (comma-separated, no spaces)
# These are the keys your external apps will use to call /api/v1/completions
VALID_API_KEYS=myai-key-prod-abc123,myai-key-dev-xyz789

# Local development only. Do not enable in production.
ALLOW_UNAUTHENTICATED=false

# ─── CORS / Authorized Origins ───────────────────────────────────────────────
# Comma-separated list of domains allowed to call the REST API
# Use * to allow all origins (not recommended for production)
ALLOWED_ORIGINS=https://yourapp.com,https://another-site.com

# Per-minute request limits
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_MODELS_PER_MINUTE=120
UI_RATE_LIMIT_PER_MINUTE=90

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Tarkari AI Assistant
NEXT_PUBLIC_APP_DESCRIPTION=Your personal Tarkari AI assistant, powered by fine-tuned open-source models.

# ─── Optional: System Prompt ─────────────────────────────────────────────────
SYSTEM_PROMPT=You are a helpful, harmless, and honest Tarkari AI assistant. You are knowledgeable, concise, and always aim to provide accurate and useful responses.
